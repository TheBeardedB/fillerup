# GitHub OAuth App
GITHUB_ID=
GITHUB_SECRET=

# Optional: first existing owner email to auto-claim legacy vehicles with NULL user_id
LEGACY_OWNER_EMAIL=

# Random secret for NextAuth (run: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Railway Postgres (set automatically if you link the service)
DATABASE_URL=

# 32-byte hex key for license plate encryption (run: openssl rand -hex 32)
LICENSE_PLATE_KEY=

# Optional: RapidAPI CarAPI (preferred lookup source when provided)
RAPIDAPI_KEY=
RAPIDAPI_CARAPI_HOST=car-api2.p.rapidapi.com
RAPIDAPI_CARAPI_BASE_URL=
RAPIDAPI_CARAPI_TRIMS_ENDPOINT=
